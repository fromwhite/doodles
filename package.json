{
  "name": "doodles",
  "type": "module",
  "version": "0.0.0",
  "description": "A starter for creating a React component library with React Compiler.",
  "author": "Author Name <author.name@mail.com>",
  "homepage": "https://github.com/author/library#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/author/library.git"
  },
  "bugs": {
    "url": "https://github.com/author/library/issues"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "play": "vite",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build",
    "build:play": "vite build playground --base=/doodles/",
    "preview:play": "vite preview playground"
  },
  "peerDependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@react-three/uikit": "^1.0.67",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "bumpp": "^11.0.1",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "vitest-browser-react": "^2.1.0",
    "wouter": "^3.9.0"
  }
}
